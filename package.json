{
  "name": "sw-color-tester",
  "version": "1.0.0",
  "description": "A Progressive Web Application (PWA) for exploring, organizing, and sharing Sherwin-Williams paint colors with comprehensive color information and visualization tools.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && npm run build:assets",
    "build:assets": "npm run build:client && npm run build:server && npm run prerender",
    "build:client": "vite build",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist-server",
    "prerender": "node prerender.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "test:e2e": "start-server-and-test \"vite preview --port 4173 --strictPort\" http://localhost:4173/sw-color-tester/ \"node scripts/validate-devices.mjs\"",
    "test:e2e:ci": "npm run build && npm run test:e2e"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "axe-core": "^4.12.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "start-server-and-test": "^3.0.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.0.1",
    "vite-plugin-pwa": "^1.3.0"
  }
}
